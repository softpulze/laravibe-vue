{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "softpulze/laravibe-vue",
    "type": "project",
    "description": "Open-source Laravel + Vue 3 starter kit with Inertia, Vite, Tailwind CSS, Shadcn Vue, and reusable utilities—optimized for clean structure and fast development. Build your app, skip the boilerplate.",
    "keywords": [
        "laravel",
        "php",
        "inertia",
        "vue",
        "starter-kit",
        "laravibe",
        "open-source"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Ashok Barua",
            "email": "ashokbaruaakas@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.16"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^v2.0.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "nunomaduro/pao": "^1.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "app/Support/Helpers.php",
            "app/Toast/Support/Helpers.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta",
            "@php artisan boost:update --ansi --discover"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "queue": "@php artisan queue:listen --tries=1 --timeout=0 --queue=default",
        "logs": "@php artisan pail -v --timeout=0",
        "vite": "npm run dev",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#fdba74,#c4b5fd,#fb7185\" \"npm run dev\" \"php artisan queue:listen --tries=1 --timeout=0 --queue=default\" \"php artisan pail -v --timeout=0\""
        ],
        "phpstan": "./vendor/bin/phpstan analyze --memory-limit=512M",
        "pest": "./vendor/bin/pest --coverage --compact",
        "test": "@pest",
        "pint:check": "./vendor/bin/pint --test",
        "pint": "./vendor/bin/pint",
        "prettier:check": "npm run format:check",
        "prettier": "npm run format",
        "format:check": [
            "@pint:check",
            "@prettier:check"
        ],
        "format": [
            "@pint",
            "@prettier"
        ],
        "eslint": "npm run lint",
        "rector": "./vendor/bin/rector",
        "lint": [
            "@rector",
            "@eslint"
        ],
        "review": [
            "@lint",
            "@format",
            "@pest",
            "@phpstan"
        ],
        "build": "npm run build",
        "build:ssr": "npm run build:ssr",
        "update:composer": "composer update",
        "update:npm": "npm update",
        "deps:update": [
            "@update:composer",
            "@update:npm"
        ],
        "logs:delete": "find storage/logs -name \"*.log\" -delete"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
